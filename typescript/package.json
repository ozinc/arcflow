{
  "name": "arcflow",
  "version": "0.1.0",
  "description": "ArcFlow TypeScript SDK — typed, ergonomic graph database access",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/ tests/",
    "lint:fix": "biome check --write src/ tests/",
    "format": "biome format --write src/ tests/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "changeset": "changeset",
    "release": "changeset publish"
  },
  "dependencies": {
    "arcflow-core": "file:../../bindings/typescript"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@changesets/cli": "^2.27.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "files": [
    "dist/"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ozinc/arcflow"
  },
  "homepage": "https://arcflow.dev/docs",
  "bugs": {
    "url": "https://github.com/ozinc/arcflow/issues"
  },
  "keywords": [
    "graph-database",
    "worldcypher",
    "cypher",
    "arcflow",
    "sdk",
    "typescript",
    "knowledge-graph",
    "vector-search",
    "graph-algorithms"
  ],
  "publishConfig": {
    "access": "public"
  }
}
